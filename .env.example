# --- Veritabani (PostgreSQL) ---
# Ucretsiz bir Postgres icin Neon (neon.tech) ya da Supabase (supabase.com) kullanabilirsin.
# Baglanti dizesini oradan alip asagiya yapistir.
DATABASE_URL="postgresql://kullanici:sifre@host:5432/veritabani?sslmode=require"

# --- NextAuth ---
# Terminalde `openssl rand -base64 32` calistirip ciktisini buraya yapistir.
NEXTAUTH_SECRET="cok-gizli-bir-anahtar-buraya"
NEXTAUTH_URL="http://localhost:3000"

# --- Tek admin hesabi (sadece bu mail giris yapabilir) ---
ADMIN_EMAIL="senin-mailin@ornek.com"
# Sifreyi hash'lemek icin: node scripts/hash-password.js "SifreN"
# ciktisini asagiya yapistir
ADMIN_PASSWORD_HASH=""

# --- AI Sohbet Asistani (Anthropic Claude) ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- Site bilgisi ---
NEXT_PUBLIC_SITE_NAME="TAKIM ADIN"
